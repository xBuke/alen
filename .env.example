# Resend — API ključ za slanje kontakt forme (samo server-side)
RESEND_API_KEY=

# Adresa koja prima upite s kontaktne forme
CONTACT_TO_EMAIL=alen.kvaternik@gmail.com

# Pošiljatelj mora biti adresa s verificirane Resend domene, npr.:
# Orguljarstvo Kvaternik <web@orguljarstvo-kvaternik.hr>
CONTACT_FROM_EMAIL=

# Javni URL stranice (canonical, sitemap, Origin provjera u produkciji)
NEXT_PUBLIC_SITE_URL=https://orguljarstvo-kvaternik.hr

# Upstash Redis za perzistentni rate limit u produkciji (preporučeno)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Duga nasumična tajna za hashiranje IP adresa pri rate limitu
RATE_LIMIT_SALT=

# Stvarne vrijednosti postavite u .env.local ili hosting secrets.
# .env.local se ne smije commitati.
